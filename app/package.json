{
  "name": "polycontrol",
  "productName": "PolyControl",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "PolyControl",
    "email": "contact@polycontrol.app"
  },
  "description": "PolyControl — Maîtrisez chaque session de jeu. Gestion complète de votre salle de gaming.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc -b && vite build && electron-builder --config electron-builder.json5",
    "electron:build:win": "tsc -b && vite build && electron-builder --config electron-builder.json5 --win",
    "electron:build:mac": "tsc -b && vite build && electron-builder --config electron-builder.json5 --mac"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "pg": "^8.22.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  }
}
